import pandas as pd
import glob
import os
from datetime import datetime, timedelta
import random

def get_album_history_simple(artist, album, training_df, master_df):
    """Lightweight version — no file reads, uses pre-loaded dataframes"""
    # Check training data
    match = training_df[
        (training_df['Album Name'] == album) &
        (training_df['Artist Name(s)'].str.contains(artist, na=False))
    ]
    if not match.empty:
        return match.iloc[0]['source_type']
    
    # Check gut scores
    if not master_df.empty:
        gut_match = master_df[
            (master_df['Album'] == album) &
            (master_df['Artist'] == artist) &
            (master_df['gut_score'].notna())
        ]
        if not gut_match.empty:
            return 'gut_scored'
    
    return 'never_rated'

# Load support data once
training_df = pd.read_csv('data/2026_training_complete_with_features.csv')
master_df = pd.read_csv('feedback/master_gut_scores.csv') if os.path.exists('feedback/master_gut_scores.csv') else pd.DataFrame()

# Get all prediction files (last 12 months)
prediction_files = []
for file in glob.glob('predictions/*_Album_Recommendations.csv'):
    try:
        date_str = os.path.basename(file).split('_')[0]
        date_obj = datetime.strptime(date_str, '%m-%d-%y')
        prediction_files.append((date_obj, file))
    except:
        continue

prediction_files.sort(key=lambda x: x[0], reverse=True)
max_date = prediction_files[0][0]
cutoff_date = max_date - timedelta(days=30*12)

all_hidden_gems = []

for date_obj, file in prediction_files:
    if date_obj < cutoff_date:
        continue
    print(f"  Checking {date_obj.strftime('%Y-%m-%d')}...")
    try:
        df = pd.read_csv(file)
        if 'Album' in df.columns and 'Album Name' not in df.columns:
            df['Album Name'] = df['Album']
        elif 'Album Name' in df.columns and 'Album' not in df.columns:
            df['Album'] = df['Album Name']
        if 'Artist Name(s)' in df.columns and 'Artist' not in df.columns:
            df['Artist'] = df['Artist Name(s)']
        if 'Predicted_Score' not in df.columns and 'avg_score' in df.columns:
            df['Predicted_Score'] = df['avg_score']

        for _, row in df.drop_duplicates(subset=['Artist', 'Album']).iterrows():
            score = row.get('Predicted_Score', 0)
            if pd.isna(score) or score < 75:
                continue
            artist = str(row.get('Artist', '')).strip()
            album = str(row.get('Album', '')).strip()
            if not artist or not album:
                continue
            history = get_album_history_simple(artist, album, training_df, master_df)
            if history == 'never_rated':
                all_hidden_gems.append({
                    'Artist': artist,
                    'Album': album,
                    'Predicted_Score': float(score),
                    'Source_Week': date_obj.strftime('%Y-%m-%d'),
                    'Genres': row.get('Genres', ''),
                    'Label': row.get('Label', '')
                })
    except Exception as e:
        print(f"    Error: {e}")
        continue

if all_hidden_gems:
    gems_df = pd.DataFrame(all_hidden_gems)
    gems_df = gems_df.sort_values('Predicted_Score', ascending=False)
    gems_df = gems_df.drop_duplicates(subset=['Artist', 'Album'], keep='first')
    gems_df.to_csv('data/hidden_gems_cache.csv', index=False)
    # Sample of 50 for quick access
    sample = gems_df.sample(n=min(50, len(gems_df)), random_state=42)
    sample.to_csv('data/hidden_gems_sample.csv', index=False)
    print(f"\n✅ Found {len(gems_df)} Hidden Gems! Saved to cache.")
    print(f"📊 Sample of {len(sample)} saved for quick access.")
else:
    print("❌ No Hidden Gems found!")


import pandas as pd, glob, os
from datetime import datetime

gems = pd.read_csv('data/hidden_gems_cache.csv')
before = len(gems)

# For any album with score < 75 or 0, try to look up real score from predictions
def lookup_real_score(artist, album):
    for f in glob.glob('predictions/*_Album_Recommendations.csv'):
        try:
            df = pd.read_csv(f)
            album_col = 'Album' if 'Album' in df.columns else 'Album Name'
            artist_col = 'Artist' if 'Artist' in df.columns else 'Artist Name(s)'
            match = df[(df[album_col] == album) & (df[artist_col].str.contains(artist, na=False))]
            if not match.empty:
                score_col = 'Predicted_Score' if 'Predicted_Score' in match.columns else 'avg_score'
                score = match.iloc[0].get(score_col, 0)
                if pd.notna(score) and float(score) > 0:
                    return float(score)
        except:
            continue
    return None

# Fix zero/missing scores
bad_mask = gems['Predicted_Score'].isna() | (gems['Predicted_Score'] < 75)
print(f"Found {bad_mask.sum()} entries with bad scores — attempting to fix...")
for idx, row in gems[bad_mask].iterrows():
    real = lookup_real_score(row['Artist'], row['Album'])
    if real and real >= 75:
        gems.at[idx, 'Predicted_Score'] = real
        print(f"  ✅ Fixed: {row['Artist']} - {row['Album']} → {real}")
    else:
        print(f"  ❌ Dropping: {row['Artist']} - {row['Album']} (score: {real})")

# Remove anything still below 75
gems = gems[gems['Predicted_Score'] >= 75]
gems.to_csv('data/hidden_gems_cache.csv', index=False)
print(f"\nRemoved {before - len(gems)} bad entries. {len(gems)} remaining.")


