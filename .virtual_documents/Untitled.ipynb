import pandas as pd, requests, time, os

LASTFM_API_KEY = "74a510ecc9fc62bf3e0edc6adc2e99f9"

def get_lastfm_album_info(artist, album, api_key):
    """Pull genres (tags) and other metadata from Last.fm for an album"""
    try:
        url = "http://ws.audioscrobbler.com/2.0/"
        params = {
            'method': 'album.getinfo',
            'api_key': api_key,
            'artist': artist,
            'album': album,
            'format': 'json'
        }
        r = requests.get(url, params=params, timeout=10)
        r.raise_for_status()
        data = r.json()
        
        if 'album' not in data:
            return None, None
        
        album_data = data['album']
        
        # Extract top 5 tags as genres
        tags = album_data.get('tags', {}).get('tag', [])
        if isinstance(tags, dict):
            tags = [tags]
        genres = ','.join([t['name'] for t in tags[:5]]) if tags else None
        
        # Extract record label from wiki summary if available
        label = None
        
        return genres, label
        
    except Exception as e:
        return None, None

def get_lastfm_artist_similar(artist, api_key):
    """Pull similar artists from Last.fm"""
    try:
        url = "http://ws.audioscrobbler.com/2.0/"
        params = {
            'method': 'artist.getSimilar',
            'api_key': api_key,
            'artist': artist,
            'limit': 10,
            'format': 'json'
        }
        r = requests.get(url, params=params, timeout=10)
        r.raise_for_status()
        data = r.json()
        
        similar = data.get('similarartists', {}).get('artist', [])
        if not similar:
            return None
        return ', '.join([a['name'] for a in similar[:10]])
        
    except Exception as e:
        return None

# Load training data
training_file = 'data/2026_training_complete_with_features.csv'
df = pd.read_csv(training_file)

# Load similar artists file
similar_file = 'data/liked_artists_only_similar.csv'
similar_df = pd.read_csv(similar_file)

# Find Top 100 albums missing genres
missing_genres = df[
    (df['source_type'] == 'top_100_ranked') &
    (df['Genres'].isna())
].drop_duplicates(subset=['Album Name'])

print(f"Backfilling genres for {len(missing_genres)} albums...")
print(f"Also backfilling similar artists where missing...")

genres_updated = 0
similar_updated = 0

for i, (_, row) in enumerate(missing_genres.iterrows()):
    artist = str(row['Artist Name(s)']).split(';')[0].split(',')[0].strip()
    album = str(row['Album Name']).strip()
    
    print(f"  {i+1}/{len(missing_genres)} {artist} - {album}")
    
    # Fetch genres from Last.fm
    genres, _ = get_lastfm_album_info(artist, album, LASTFM_API_KEY)
    
    if genres:
        df.loc[
            (df['Album Name'] == album) & 
            (df['Artist Name(s)'].str.contains(artist, na=False)),
            'Genres'
        ] = genres
        genres_updated += 1
        print(f"    ✅ Genres: {genres}")
    else:
        print(f"    ❌ No genres found")
    
    # Also check if similar artists are missing for this artist
    similar_match = similar_df[similar_df['Artist'] == artist]
    if similar_match.empty or similar_match.iloc[0]['Similar Artists'] != similar_match.iloc[0]['Similar Artists']:
        similar = get_lastfm_artist_similar(artist, LASTFM_API_KEY)
        if similar:
            if similar_match.empty:
                new_row = pd.DataFrame([{'Artist': artist, 'Similar Artists': similar}])
                similar_df = pd.concat([similar_df, new_row], ignore_index=True)
            else:
                similar_df.loc[similar_df['Artist'] == artist, 'Similar Artists'] = similar
            similar_updated += 1
            print(f"    ✅ Similar: {similar[:50]}...")
    
    time.sleep(0.25)  # respect rate limits

# Save both files
df.to_csv(training_file, index=False)
similar_df.to_csv(similar_file, index=False)

print(f"\n✅ Done!")
print(f"   Genres backfilled: {genres_updated}/{len(missing_genres)}")
print(f"   Similar artists updated: {similar_updated}")


import pandas as pd
JUNK_TAGS = [
    'seen live', 'albums i own', 'favorite albums', 'favourites', 
    'my favorites', 'owned', 'wishlist', 'to listen', 'heard of',
    'love', 'awesome', 'good', 'great', 'best', 'classic'
]
df = pd.read_csv('data/2026_training_complete_with_features.csv')
def clean_genres(genre_str):
    if pd.isna(genre_str):
        return genre_str
    tags = [t.strip() for t in genre_str.split(',')]
    cleaned = [
        t for t in tags
        if t.lower() not in JUNK_TAGS
        and not t.strip().replace('s', '').isnumeric()
        and len(t.strip().split()) <= 4
    ]
    return ','.join(cleaned) if cleaned else None
df['Genres'] = df['Genres'].apply(clean_genres)
df.to_csv('data/2026_training_complete_with_features.csv', index=False)
print("✅ Junk tags cleaned.")

