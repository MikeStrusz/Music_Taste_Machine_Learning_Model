import pandas as pd, glob, os, hashlib

def cover_filename(artist, album):
    key = f"{str(artist).strip().lower()}_{str(album).strip().lower()}"
    return os.path.join('covers', hashlib.md5(key.encode()).hexdigest() + '.jpg')

# Find all 2026 prediction files
covers_2026 = set()
for f in glob.glob('predictions/*_Album_Recommendations.csv'):
    date_str = os.path.basename(f).split('_')[0]
    try:
        from datetime import datetime
        d = datetime.strptime(date_str, '%m-%d-%y')
        if d.year == 2026:
            df = pd.read_csv(f)
            artist_col = 'Artist' if 'Artist' in df.columns else 'Artist Name(s)'
            album_col = 'Album' if 'Album' in df.columns else 'Album Name'
            for _, row in df[[artist_col, album_col]].drop_duplicates().iterrows():
                fname = os.path.basename(cover_filename(str(row[artist_col]), str(row[album_col])))
                covers_2026.add(fname)
    except:
        continue

print(f"2026 cover files to keep: {len(covers_2026)}")
print(f"Total covers on disk: {len(os.listdir('covers'))}")
print(f"Would exclude: {len(os.listdir('covers')) - len(covers_2026)}")


import shutil, os

os.makedirs('covers_deploy', exist_ok=True)
for fname in covers_2026:
    src = os.path.join('covers', fname)
    dst = os.path.join('covers_deploy', fname)
    if os.path.exists(src):
        shutil.copy(src, dst)
print(f"✅ Copied {len(os.listdir('covers_deploy'))} files to covers_deploy/")


import shutil, os, glob

# Copy all covers_deploy files back into covers (they're already there, this is just cleanup)
for f in glob.glob('covers_deploy/*.jpg'):
    fname = os.path.basename(f)
    dst = os.path.join('covers', fname)
    if not os.path.exists(dst):
        shutil.copy(f, dst)

# Remove covers_deploy folder
shutil.rmtree('covers_deploy')
print("✅ Done — covers_deploy removed, all files back in covers/")
print(f"Total covers: {len(os.listdir('covers'))}")


