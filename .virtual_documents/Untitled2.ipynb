# 4. Check the vault endpoint response for a sample album that should have a cover
import requests

# Pick an album that we think should have a cover
sample_artist = "Miss Grit"  # you can change to one you know
sample_album = "Follow the Cyborg"

# Get the vault data
resp = requests.get('http://localhost:8000/vault')
if resp.status_code == 200:
    vault_data = resp.json()
    # Find the album in the vault data
    for item in vault_data:
        if item.get('Artist') == sample_artist and item.get('Album') == sample_album:
            print(f"\nVault entry for {sample_artist} - {sample_album}:")
            print(f"  Album Art: {item.get('Album Art')}")
            break
    else:
        print(f"\nAlbum not found in vault data.")
else:
    print(f"Failed to fetch vault: {resp.status_code}")


