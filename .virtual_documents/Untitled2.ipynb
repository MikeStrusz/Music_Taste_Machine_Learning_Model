import pandas as pd
import glob

files = glob.glob('data/top_100_*.csv') + glob.glob('data/top_50_*.csv')
for f in sorted(files):
    try:
        df = pd.read_csv(f, encoding='latin-1')
        print(f"✅ {f} — {len(df)} rows, columns: {df.columns.tolist()}")
    except Exception as e:
        print(f"❌ {f} — ERROR: {e}")


