import pandas as pd
import glob
import os
from datetime import datetime

# Load training data
training_df = pd.read_csv('data/2026_training_complete_with_features.csv')
# Top 50 from training
top50 = training_df[
    (training_df['source_type'] == 'top_100_ranked') &
    (training_df['liked'] >= 80)
][['Album Name', 'Artist Name(s)']].drop_duplicates()
print(f"Top 50 from training: {len(top50)}")

# Load gut scores
master_file = 'feedback/master_gut_scores.csv'
if os.path.exists(master_file):
    gut_df = pd.read_csv(master_file)
    gut_df['gut_score_date'] = pd.to_datetime(gut_df['gut_score_date'], errors='coerce')
    high_gut = gut_df[
        (gut_df['gut_score'] >= 80) &
        (gut_df['gut_score_date'].dt.year < datetime.now().year)
    ]
    print(f"High gut from previous years: {len(high_gut)}")
else:
    high_gut = pd.DataFrame()
    print("No master file")

# Combine
old_fav_candidates = []
for _, row in top50.iterrows():
    old_fav_candidates.append((row['Artist Name(s)'].split(';')[0].split(',')[0].strip(), row['Album Name']))
for _, row in high_gut.iterrows():
    old_fav_candidates.append((row['Artist'], row['Album']))
print(f"Total Old Fav candidates: {len(old_fav_candidates)}")


# Build set of already rated (training + gut)
already_rated = set()
for _, row in training_df[['Album Name', 'Artist Name(s)']].drop_duplicates().iterrows():
    artist = row['Artist Name(s)'].split(';')[0].split(',')[0].strip()
    already_rated.add((artist, row['Album Name']))

if os.path.exists(master_file):
    for _, row in gut_df.iterrows():
        already_rated.add((row['Artist'], row['Album']))

print(f"Already rated albums count: {len(already_rated)}")


# Collect New Potential
new_potential = []
for f in glob.glob('predictions/*_Album_Recommendations.csv'):
    df = pd.read_csv(f)
    score_col = 'Predicted_Score' if 'Predicted_Score' in df.columns else 'avg_score'
    date_str = os.path.basename(f).split('_')[0]
    date_obj = datetime.strptime(date_str, '%m-%d-%y')
    for _, row in df.iterrows():
        score = row.get(score_col, 0)
        if pd.isna(score) or score < 75:
            continue
        artist = str(row.get('Artist', row.get('Artist Name(s)', ''))).strip()
        album = str(row.get('Album', row.get('Album Name', ''))).strip()
        # Exclude already rated
        if (artist, album) not in already_rated:
            new_potential.append((artist, album, score, date_obj))
print(f"New Potential candidates: {len(new_potential)}")


