import glob, os
files = glob.glob('predictions/*_Album_Recommendations.csv')
years = set()
for f in files:
    parts = os.path.basename(f).split('_')[0].split('-')
    if len(parts) == 3:
        years.add('20' + parts[2])
print(sorted(years))
