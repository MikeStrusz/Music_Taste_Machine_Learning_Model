    'We Are The Wilows': 'We Are The Willows',
    'Missio': 'MISSIO',
    'Raye': 'RAYE',
    'charlie houston': 'Charlie Houston',
    'DaFFo': 'Daffo',
    'Fontaines DC': 'Fontaines D.C.',
    'Noel Gallaghers High Flying Birds': "Noel Gallagher's High Flying Birds",
    'Dangermouse/Blackthought': 'Danger Mouse & Black Thought',
    'BeyoncÃ©': 'Beyoncé',
    'ROSALÃA': 'ROSALÍA',
    'SÃ¸nntag': 'Sønntag',
    'Honne': 'HONNE',
    'Sault': 'SAULT',
    'Pup': 'PUP',
    'Thick': 'THICK',
}

vault['Artist_corrected'] = vault['Artist'].str.strip().replace(corrections)
